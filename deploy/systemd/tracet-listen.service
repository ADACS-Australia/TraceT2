[Unit]
Description=TraceT (Listen)
After=tracet.service
WantedBy=tracet.service
PartOf=tracet.service

[Service]
Type=simple
WorkingDirectory=/home/debian/TraceT/deploy
ExecStart=/usr/bin/podman compose --profile prod up --remove-orphans --exit-code-from listen listen
ExecStop=/usr/bin/podman compose --profile prod down --remove-orphans listen
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
